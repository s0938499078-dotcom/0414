public class PassingCounter { // 必須有這個外殼

    public static void main(String[] args) {
        // 這是測試用的範例輸入
        int[] testScores = {45, 60, 80, 59, 100};
        countPassing(testScores);
    }

    // 第六題：這就是你的方法
    public static void countPassing(int[] scores) {
        int count = 0;
        for (int score : scores) {
            if (score >= 60) {
                count++;
            }
        }
        System.out.println("Number of passing students: " + count);
    }
}
